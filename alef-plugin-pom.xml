<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

	<parent>
        <groupId>nl.belastingdienst.brm.alef</groupId>
        <artifactId>alef</artifactId>
		<version>0.0.0</version>
        <relativePath>./pom.xml</relativePath>
    </parent>

    <groupId>nl.belastingdienst.brm.alef</groupId>
    <artifactId>openAlefStudio</artifactId>
	<packaging>pom</packaging>

	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<branch>feature/${project.version}</branch>
		<jenkins.buildnumber>1</jenkins.buildnumber>

		<mps.version>2025.1</mps.version>
		<extensions.version>2025.1.3226.9d3d593</extensions.version>
		<jbr.version>21.0.6-b631.39</jbr.version>
		<jbr.type>tgz</jbr.type>
		<jbr.classifier/>
		<java.home/>
		<mps.home>${project.build.directory}/mps-${mps.version}</mps.home>
	</properties>

	<dependencies>
		<dependency>
			<groupId>com.jetbrains.jdk</groupId>
			<artifactId>jbr</artifactId>
			<version>${jbr.version}</version>
			<classifier>linux-x64</classifier>
			<type>tgz</type>
		</dependency>
		<dependency>
			<groupId>com.jetbrains.jdk</groupId>
			<artifactId>jbr</artifactId>
			<version>${jbr.version}</version>
			<classifier>windows-x64</classifier>
			<type>tgz</type>
		</dependency>
		<dependency>
			<groupId>com.jetbrains.jdk</groupId>
			<artifactId>jbr</artifactId>
			<version>${jbr.version}</version>
			<classifier>osx-x64</classifier>
			<type>tgz</type>
		</dependency>
		<dependency>
			<groupId>com.jetbrains.jdk</groupId>
			<artifactId>jbr</artifactId>
			<version>${jbr.version}</version>
			<classifier>osx-aarch64</classifier>
			<type>tgz</type>
		</dependency>

		<dependency>
			<groupId>com.jetbrains</groupId>
			<artifactId>mps</artifactId>
			<version>${mps.version}</version>
			<type>zip</type>
		</dependency>
		<dependency>
			<groupId>de.itemis.mps</groupId>
			<artifactId>extensions</artifactId>
			<version>${extensions.version}</version>
			<type>zip</type>
		</dependency>
		<dependency>
	           	<groupId>nl.belastingdienst.brm.alef</groupId>
	           	<artifactId>alefRuntime</artifactId>
	           	<version>${project.version}</version>
	    </dependency>
		<dependency>
			<groupId>nl.belastingdienst.brm.alef</groupId>
			<artifactId>servicelogger</artifactId>
			<version>2023.1.0</version>
		</dependency>
		<dependency>
			<groupId>nl.belastingdienst.brm.alef</groupId>
			<artifactId>merlin</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>nl.belastingdienst.brm.alef</groupId>
			<artifactId>serviceTestRuntime</artifactId>
			<version>${project.version}</version>
		</dependency>

		<dependency>
			<groupId>jakarta.xml.bind</groupId>
			<artifactId>jakarta.xml.bind-api</artifactId>
			<version>4.0.4</version>
		</dependency>
		<dependency>
			<groupId>com.sun.xml.bind</groupId>
			<artifactId>jaxb-impl</artifactId>
			<version>4.0.3</version>
			<scope>runtime</scope>
		</dependency>
		<dependency>
			<groupId>jakarta.jws</groupId>
			<artifactId>jakarta.jws-api</artifactId>
			<version>${jakartaJwsApi.version}</version>
		</dependency>
		<dependency>
			<groupId>jakarta.ws.rs</groupId>
			<artifactId>jakarta.ws.rs-api</artifactId>
			<version>${jakartaWsRsApi.version}</version>
		</dependency>
		<dependency>
			<groupId>jakarta.xml.ws</groupId>
			<artifactId>jakarta.xml.ws-api</artifactId>
			<version>${jakartaXmlWsApi.version}</version>
		</dependency>
		<dependency>
			<groupId>jakarta.xml.soap</groupId>
			<artifactId>jakarta.xml.soap-api</artifactId>
			<version>${jakartaXmlSoapApi.version}</version>
		</dependency>

		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-annotations</artifactId>
			<version>${jackson-annotations.version}</version>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
			<version>${jackson-databind.version}</version>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.datatype</groupId>
			<artifactId>jackson-datatype-jsr310</artifactId>
			<version>${jackson-databind.version}</version>
		</dependency>

        <dependency>
            <groupId>org.apache.xmlgraphics</groupId>
            <artifactId>batik-all</artifactId>
            <version>1.19</version>
            <type>pom</type>
        </dependency>

		<dependency>
			<groupId>org.apache.poi</groupId>
			<artifactId>poi</artifactId>
			<version>5.5.1</version>
		</dependency>
		<dependency>
			<groupId>org.apache.poi</groupId>
			<artifactId>poi-ooxml</artifactId>
			<version>5.5.1</version>
		</dependency>
	</dependencies>

    <build>
		<finalName>${project.artifactId}-${project.version}</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.1</version>
                <configuration>
                    <source>11</source>
                    <target>11</target>
                </configuration>
            </plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-dependency-plugin</artifactId>
				<version>3.1.2</version>
				<executions>
					<!-- Copy jbrs om distributies van alefstudio voor macos/win/linux te kunnen maken -->
                    <execution>
                        <id>copy-jbrs</id>
                        <phase>compile</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                	<groupId>com.jetbrains.jdk</groupId>
                                	<artifactId>jbr</artifactId>
                                	<version>${jbr.version}</version>
									<classifier>linux-x64</classifier>
                                	<type>tgz</type>
                                	<outputDirectory>
                                   		${project.basedir}/build/jbrs
                                	</outputDirectory>
                                	<destFileName>jbr-linux-x64.tar.gz</destFileName>
                                </artifactItem>
                                <artifactItem>
									<groupId>com.jetbrains.jdk</groupId>
									<artifactId>jbr</artifactId>
									<version>${jbr.version}</version>
									<classifier>osx-x64</classifier>
									<type>tgz</type>
									<outputDirectory>
									   ${project.basedir}/build/jbrs
									</outputDirectory>
                                	<destFileName>jbr-osx-x64.tar.gz</destFileName>
                                </artifactItem>
								<artifactItem>
									<groupId>com.jetbrains.jdk</groupId>
									<artifactId>jbr</artifactId>
									<version>${jbr.version}</version>
									<classifier>osx-aarch64</classifier>
									<type>tgz</type>
									<outputDirectory>
									   ${project.basedir}/build/jbrs
									</outputDirectory>
                                	<destFileName>jbr-osx-aarch64.tar.gz</destFileName>
                                </artifactItem>
                                <artifactItem>
									<groupId>com.jetbrains.jdk</groupId>
									<artifactId>jbr</artifactId>
									<version>${jbr.version}</version>
									<classifier>windows-x64</classifier>
									<type>tgz</type>
									<outputDirectory>
									   ${project.basedir}/build/jbrs
									</outputDirectory>
									<destFileName>jbr-windows-x64.tar.gz</destFileName>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>

					<!-- Copy jbr om mee te bouwen, mps, en extra mps plugins -->
					<execution>
						<id>deps</id>
						<phase>initialize</phase>
						<goals>
							<goal>unpack</goal>
						</goals>
						<configuration>
							<artifactItems>
								<artifactItem>
									<groupId>com.jetbrains.jdk</groupId>
									<artifactId>jbr</artifactId>
									<version>${jbr.version}</version>
									<classifier>${jbr.classifier}</classifier>
									<type>${jbr.type}</type>
									<fileMappers>
										<org.codehaus.plexus.components.io.filemappers.RegExpFileMapper>
											<pattern>^.[^\/]*\/</pattern>
											<replacement>jbr-${jbr.version}-${jbr.classifier}/</replacement>
										</org.codehaus.plexus.components.io.filemappers.RegExpFileMapper>
									</fileMappers>
									<outputDirectory>${project.build.directory}</outputDirectory>
									<destFileName>jbr-${jbr.version}-${jbr.classifier}.${jbr.type}</destFileName>
								</artifactItem>
								<artifactItem>
									<groupId>com.jetbrains</groupId>
									<artifactId>mps</artifactId>
									<version>${mps.version}</version>
									<type>zip</type>
									<outputDirectory>${project.build.directory}/mps-${mps.version}</outputDirectory>
									<destFileName>mps-${mps.version}.zip</destFileName>
								</artifactItem>
								<artifactItem>
									<groupId>de.itemis.mps</groupId>
									<artifactId>extensions</artifactId>
									<version>${extensions.version}</version>
									<type>zip</type>
									<fileMappers>
										<org.codehaus.plexus.components.io.filemappers.RegExpFileMapper>
											<pattern>^.[^\/]*\/</pattern>
											<replacement>./</replacement>
										</org.codehaus.plexus.components.io.filemappers.RegExpFileMapper>
									</fileMappers>
									<outputDirectory>${project.build.directory}/extra-mps-plugins</outputDirectory>
									<destFileName>extensions-${extensions.version}.zip</destFileName>
								</artifactItem>
								</artifactItems>
						</configuration>
					</execution>

					<!-- copy Apache Batik to the expected location -->
					<execution>
						<id>copy-batik</id>
						<phase>initialize</phase>
						<goals>
							<goal>copy</goal>
						</goals>
						<configuration>
							<artifactItems>
								<artifactItem>
								<groupId>org.apache.xmlgraphics</groupId>
								<artifactId>batik-all</artifactId>
								<version>1.17</version>
								<type>jar</type>
								<outputDirectory>
								   ${project.basedir}/solutions/org.apache.batik/lib
								</outputDirectory>
								<destFileName>batik-all.jar</destFileName>
								</artifactItem>
							</artifactItems>
						</configuration>
					</execution>

					<!-- copy Apache POI to the expected location -->
					<execution>
						<id>copy-apache-poi-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>org.apache.poi,org.apache.xmlbeans,commons-io,commons-codec,org.apache.commons,com.github.virtuald,org.apache.commons,com.zaxxer,org.apache.logging.log4j</includeGroupIds>
							<includeArtifactIds>poi,poi-ooxml,poi-ooxml-lite,xmlbeans,commons-io,commons-codec,commons-compress,curvesapi,commons-collections4,commons-math3,SparseBitSet,log4j-api</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/org.apache.poi/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>

					<!-- Copy alefRuntime.jar to the expected location -->
					<execution>
						<id>copy-alefRuntime-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>nl.belastingdienst.brm.alef</includeGroupIds>
							<includeArtifactIds>alefRuntime</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/alef.runtime/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>
					<!-- Copy org.jetbrains.annotations to the expected location -->
					<execution>
						<id>copy-jetbrains-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>org.jetbrains</includeGroupIds>
							<includeArtifactIds>annotations</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/alef.runtime/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>
                    <!-- Copy merlin.jar to the expected location -->
					<execution>
						<id>copy-merlin-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>nl.belastingdienst.brm.alef</includeGroupIds>
							<includeArtifactIds>merlin, servicelogger</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/alef.runtime/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>
					<!-- Copy J2EE jakarta voor v8 to the expected location -->
					<execution>
						<id>copy-jakarta-8-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>jakarta.xml.bind,com.sun.xml.bind,jakarta.xml.ws,jakarta.jws,jakarta.xml.soap,jakarta.ws.rs,com.fasterxml.jackson.core,com.fasterxml.jackson.datatype</includeGroupIds>
							<includeArtifactIds>jakarta.xml.bind-api,com.sun.xml.bind,jakarta.xml.ws-api,jakarta.jws-api,jakarta.xml.soap-api,jakarta.ws.rs-api,jackson-annotations,jackson-databind,jackson-core,jackson-datatype-jsr310</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/alef.runtime/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>

					<!-- Copy serviceTestRuntime.jar to the expected location -->
					<execution>
						<id>copy-service-test-dependencies</id>
						<phase>compile</phase>
						<goals>
							<goal>copy-dependencies</goal>
						</goals>
						<configuration>
							<includeGroupIds>nl.belastingdienst.brm.alef</includeGroupIds>
							<includeArtifactIds>serviceTestRuntime</includeArtifactIds>
							<outputDirectory>${project.basedir}/solutions/serviceTest.runtime/lib</outputDirectory>
							<stripVersion>true</stripVersion>
							<overWriteReleases>true</overWriteReleases>
							<overWriteSnapshots>true</overWriteSnapshots>
							<overWriteIfNewer>true</overWriteIfNewer>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<version>2.4</version>
				<configuration>
					<skipIfEmpty>true</skipIfEmpty>
					<skip>${alef.install-deps}</skip>
					<archive>
						<addMavenDescriptor>false</addMavenDescriptor>
					</archive>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>1.1.1</version>
				<executions>
					<execution>
						<id>build-alef</id>
						<phase>compile</phase>
						<configuration>
							<skip>${alef.install-deps}</skip>
							<environmentVariables>
								<MPS_HOME>${mps.home}</MPS_HOME>
								<ALEF_HOME>.</ALEF_HOME>
								<MPS_JDK>${java.home}</MPS_JDK>
								<PROJECT_VERSION>${project.version}</PROJECT_VERSION>
								<NO_ARTIFACTS_CLEAN>${env.NO_ARTIFACTS_CLEAN}</NO_ARTIFACTS_CLEAN>
								<BRANCH_NAME>${env.BRANCH_NAME}</BRANCH_NAME>
								<VERSION_NUMBER>${project.version}</VERSION_NUMBER>
								<BUILD_NUMBER>${env.BUILD_NUMBER}</BUILD_NUMBER>
							</environmentVariables>
							<executable>bash</executable>
							<arguments>
								<argument>scripts/build-plain.sh</argument>
							</arguments>
						</configuration>
						<goals>
							<goal>exec</goal>
						</goals>
					</execution>
					<execution>
						<id>build-services</id>
						<phase>test</phase>
						<configuration>
							<skip>${alef.install-deps}</skip>
							<workingDirectory>${project.basedir}</workingDirectory>
							<executable>${env.JAVA_HOME}/bin/java</executable>
							<workingDirectory>${project.basedir}</workingDirectory>
							<environmentVariables>
								<MPS_HOME>${mps.home}</MPS_HOME>
								<ALEF_HOME>${project.basedir}</ALEF_HOME>
							</environmentVariables>
							<arguments>
								<argument>-jar</argument>
								<argument>build/artifacts/alef-plugin/Alef/project-build/alefProjectBuild.jar</argument>
								<argument>service</argument>
							</arguments>
						</configuration>
						<goals>
							<goal>exec</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>build-helper-maven-plugin</artifactId>
				<version>3.3.0</version>
				<executions>
					<execution>
						<id>attach-artifacts</id>
						<phase>package</phase>
						<goals>
							<goal>attach-artifact</goal>
						</goals>
						<configuration>
							<skipAttach>${alef.install-deps}</skipAttach>
							<artifacts>
								<artifact>
									<file>./build/artifacts/alef-distribution/alef-plugin.zip</file>
									<type>zip</type>
									<classifier>mps</classifier>
								</artifact>
								<artifact>
									<file>./build/artifacts/alef-distribution/alef-linux.tar.gz</file>
									<type>tgz</type>
									<classifier>linux</classifier>
								</artifact>
								<artifact>
									<file>./build/artifacts/alef-distribution/alef-windows.zip</file>
									<type>zip</type>
									<classifier>windows</classifier>
								</artifact>
								<artifact>
									<file>./build/artifacts/alef-distribution/alef-MacOSaarch64.zip</file>
									<type>zip</type>
									<classifier>macos-aarch64</classifier>
								</artifact>
							</artifacts>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<artifactId>maven-assembly-plugin</artifactId>
				<version>3.4.2</version>
				<configuration>
					<attach>false</attach>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-deploy-plugin</artifactId>
				<version>3.1.1</version>
				<executions>
					<execution>
						<id>default-deploy</id>
						<phase>deploy</phase>
						<goals>
							<goal>deploy</goal>
						</goals>
						<configuration>
							<skip>${alef.install-deps}</skip>
						</configuration>
					</execution>
				</executions>
			</plugin>
        </plugins>
    </build>
	<profiles>
		<profile>
			<id>default</id>
			<activation><activeByDefault>true</activeByDefault></activation>
			<properties>
				<alef.install-deps>false</alef.install-deps>
				<jbr.classifier>linux-x64</jbr.classifier>
				<java.home>${project.build.directory}/jbr-${jbr.version}-${jbr.classifier}</java.home>
			</properties>
		</profile>
		<profile>
			<id>install-deps</id>
			<properties>
				<alef.install-deps>true</alef.install-deps>
				<maven.test.skip>true</maven.test.skip>
			</properties>
		</profile>
		<profile>
			<id>Linux</id>
			<activation>
				<os>
					<family>unix</family>
				</os>
			</activation>
			<properties>
				<mps.platform>linux</mps.platform>
				<jbr.classifier>linux-x64</jbr.classifier>
				<java.home>${project.build.directory}/jbr-${jbr.version}-${jbr.classifier}</java.home>
			</properties>
		</profile>
		<profile>
			<id>Windows</id>
			<activation>
				<os>
					<family>windows</family>
				</os>
			</activation>
			<properties>
				<mps.platform>windows</mps.platform>
				<jbr.classifier>windows-x64</jbr.classifier>
				<java.home>${project.build.directory}/jbr-${jbr.version}-${jbr.classifier}</java.home>
			</properties>
		</profile>
		<profile>
			<!-- MacOS: Intel -->
			<id>MacOSx64</id>
			<activation>
				<os>
					<family>mac</family>
					<arch>x64</arch>
				</os>
			</activation>
			<properties>
				<jbr.classifier>osx-x64</jbr.classifier>
				<java.home>${project.build.directory}/jbr-${jbr.version}-${jbr.classifier}/Contents/Home</java.home>
				<maven.test.skip>true</maven.test.skip>
			</properties>
		</profile>
		<profile>
			<!-- MacOS: Apple Silicon -->
			<id>MacOSaarch64</id>
			<activation>
				<os>
					<family>mac</family>
					<arch>aarch64</arch>
				</os>
			</activation>
			<properties>
				<jbr.classifier>osx-aarch64</jbr.classifier>
				<java.home>${project.build.directory}/jbr-${jbr.version}-${jbr.classifier}/Contents/Home</java.home>
				<maven.test.skip>true</maven.test.skip>
			</properties>
		</profile>
	</profiles>
</project>
